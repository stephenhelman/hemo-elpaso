generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

enum EventTopic {
  EDUCATION
  SOCIAL
  FUNDRAISING
  ADVOCACY
  YOUTH
  FAMILY_SUPPORT
  MEDICAL_UPDATE
  FINANCIAL_ASSISTANCE
}

enum DietaryRestriction {
  NONE
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
  NUT_ALLERGY
  HALAL
  KOSHER
  OTHER
}

model PatientPreferences {
  id                    String              @id @default(uuid())
  patientId             String              @unique
  patient               Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  // Event preferences
  interestedTopics      EventTopic[]
  preferredEventTimes   String[]            // ["weekday_evening", "weekend_morning", "weekend_afternoon"]
  maxTravelDistance     Int?                // miles willing to travel
  
  // Accessibility & dietary
  dietaryRestrictions   DietaryRestriction[]
  accessibilityNeeds    String?             // wheelchair, ASL interpreter, etc
  
  // Communication preferences
  emailNotifications    Boolean             @default(true)
  smsNotifications      Boolean             @default(false)
  languagePreference    String              @default("en")  // en, es
  
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@map("patient_preferences")
}

model Patient {
  id                 String            @id @default(uuid())
  auth0Id            String            @unique
  email              String            @unique
  role               String            @default("patient")
  preferredLanguage  String            @default("en")
  consentDate        DateTime?
  consentToContact   Boolean           @default(false)
  consentToPhotos    Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  profile            PatientProfile?
  preferences        PatientPreferences?
  familyMembers      FamilyMember[]
  rsvps              Rsvp[]
  checkIns           CheckIn[]
  auditLogs          AuditLog[]        // ADD THIS

  @@map("patients")
}

model PatientProfile {
  id               String   @id @default(uuid())
  patientId        String   @unique
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  phone            String
  address          String   
  city             String   
  state            String  
  zipCode          String   
  primaryCondition        String
  severity         String
  diagnosisDate    DateTime
  treatingPhysician String?  
  specialtyPharmacy String?  
  emergencyContactName String
  emergencyContactRelationship String
  emergencyContactPhone String
  hipaaConsent Boolean
  photoConsent Boolean
  communicationConsent Boolean
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("patient_profiles")
}

model FamilyMember {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  relationship String  // parent, child, spouse, sibling, other
  hasBleedingDisorder Boolean @default(false)
  condition   String?  // if hasBleedingDisorder is true
  severity    String?  // mild, moderate, severe
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("family_members")
}

model Event {
  id            String    @id @default(uuid())
  slug          String    @unique
  titleEn       String
  titleEs       String
  descriptionEn String?
  descriptionEs String?
  eventDate     DateTime
  location      String
  maxCapacity   Int?    
  rsvpDeadline  DateTime?
  status        String    @default("draft") // draft, published, cancelled, completed
  
  category      String    @default("FAMILY_SUPPORT") // Maps to EventTopic enum
  targetAudience String   @default("all") // all, youth, adults, families
  language      String    @default("both") // en, es, both
  isPriority    Boolean   @default(false)
  liveEnabled   Boolean   @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  targeting     EventTargeting?
  rsvps         Rsvp[]
  checkIns      CheckIn[]
  interactions  EventInteraction[]
  pollCreationTokens PollCreationToken[]
  photos        EventPhoto[]
  questions     EventQuestion[]

  @@map("events")
}

model EventTargeting {
  id                String   @id @default(uuid())
  eventId           String   @unique
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  targetConditions  String[] // hemophilia_a, hemophilia_b, von_willebrand, other
  targetSeverity    String[] // mild, moderate, severe
  targetAgeGroups   String[] // children, teens, adults, seniors
  targetInterests   String[] // Can map to EventTopic enum values
  requireInhibitors Boolean?
  
  @@map("event_targeting")
}

model Rsvp {
  id                  String   @id @default(uuid())
  eventId             String
  patientId           String
  event               Event    @relation(fields: [eventId], references: [id])
  patient             Patient  @relation(fields: [patientId], references: [id])
  status              String   @default("confirmed")
  adultsAttending     Int      @default(1)
  childrenAttending   Int      @default(0)
  dietaryRestrictions String?
  specialNeeds        String?
  rsvpDate            DateTime @default(now())
  updatedAt           DateTime @updatedAt
  reminderSent        Boolean  @default(false) 

  @@unique([eventId, patientId])
}

model CheckIn {
  id               String   @id @default(uuid())
  eventId          String
  patientId        String
  event            Event    @relation(fields: [eventId], references: [id])
  patient          Patient  @relation(fields: [patientId], references: [id])
  checkInTime      DateTime @default(now())
  checkedInBy      String?
  sessionToken     String   @unique
  sessionExpiresAt DateTime

  @@unique([eventId, patientId])
}

model EventInteraction {
  id            String    @id @default(uuid())
  eventId       String
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  type          String    // 'poll', 'question', 'announcement'
  titleEn       String
  titleEs       String
  options       Json?     // For polls: {options: [{id, text}]}
  
  status        String    @default("draft") // draft, pending, approved, active, completed
  active        Boolean   @default(false)
  sequenceOrder Int       @default(0)
  
  createdBy     String?   // admin email or "rep:{repEmail}"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  responses     InteractionResponse[]
  
  @@map("event_interactions")
}

model PollCreationToken {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  token       String   @unique
  repEmail    String
  repName     String?
  expiresAt   DateTime
  
  createdBy   String   // admin who generated the link
  createdAt   DateTime @default(now())
  
  @@map("poll_creation_tokens")
}

model InteractionResponse {
  id            String           @id @default(uuid())
  interactionId String
  interaction   EventInteraction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  sessionToken  String
  responseData  Json
  createdAt     DateTime         @default(now())
  
  @@map("interaction_responses")
}

model EventQuestion {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])

  // Question Content
  questionEn String
  questionEs String
  originalLang String @default("en")

  //submitter info
  patientId String?
  patientName String?
  isAnonymous Boolean @default(false)
  sessionToken String

  // Engagement
  upvotes Int @default(0)
  upvotedBy String[] @default([])

  // Answer
  answered Boolean @default(false)
  answerEn String?
  answerEs String?
  answeredBy String?
  answeredAt DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EventPhoto {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id])
  s3Key         String
  cloudfrontUrl String
  captionEn     String?
  captionEs     String?
  approved      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(uuid())
  patientId    String?  // ADD THIS
  patient      Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  action       String
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  details      String?  // ADD THIS - simpler than Json for most cases
  changes      Json?    // Keep this for complex data
  createdAt    DateTime @default(now())

  @@map("audit_logs")
}