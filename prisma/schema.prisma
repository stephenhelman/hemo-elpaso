generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum EventTopic {
  EDUCATION
  SOCIAL
  FUNDRAISING
  ADVOCACY
  YOUTH
  FAMILY_SUPPORT
  MEDICAL_UPDATE
  FINANCIAL_ASSISTANCE
}

enum DietaryRestriction {
  NONE
  VEGETARIAN
  VEGAN
  GLUTEN_FREE
  DAIRY_FREE
  NUT_ALLERGY
  HALAL
  KOSHER
  OTHER
}

enum AssistanceType {
  EVENT_FEES
  TRANSPORTATION
  MEDICATION
  MEDICAL_EQUIPMENT
  EMERGENCY_SUPPORT
  OTHER
}

enum AssistanceStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
  DISBURSED
  CLOSED
}

enum DisbursementStatus {
  PENDING
  ISSUED
  CASHED
  VOID
}

enum PaymentMethod {
  CHECK
  CASH
  REIMBURSEMENT
}

enum EmailTemplateType {
  RSVP_CONFIRMATION
  RSVP_CANCELLATION
  RSVP_REMINDER
  CHECK_IN_CONFIRMATION
  EVENT_PUBLISHED
  EVENT_CANCELLED
  ASSISTANCE_SUBMITTED
  ASSISTANCE_APPROVED
  ASSISTANCE_DENIED
  DISBURSEMENT_ISSUED
  WELCOME_EMAIL
  VOLUNTEER_REQUEST_RECEIVED
  VOLUNTEER_REQUEST_NOTIFY
  VOLUNTEER_APPROVED
  VOLUNTEER_ASSIGNED
}

enum AgeTier {
  RECORD_ONLY
  YOUTH
  ADULT
}

enum FamilyMembershipStatus {
  ACTIVE
  PENDING_INVITE
  DETACHED
}

enum BoardApprovalType {
  FAMILY_DETACHMENT
  VOLUNTEER_APPROVAL
  ROLE_ASSIGNMENT
}

enum BoardApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

enum VolunteerStatus {
  PENDING_REVIEW
  APPROVED
  INACTIVE
  REJECTED
}

enum VolunteerEventRole {
  CHECK_IN_STAFF
  REGISTRATION_TABLE
  SETUP_CREW
  TEARDOWN_CREW
  HOSPITALITY
  ACTIVITIES
  GENERAL_SUPPORT
  OTHER
}

enum BoardRoleType {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  SECRETARY
  EVENTS_COORDINATOR  
  SPONSOR_LIAISON
  COMMUNICATIONS_LEAD
  YOUTH_COORDINATOR
  VOLUNTEER_COORDINATOR
  FUNDRAISING_COORDINATOR
  BOARD_MEMBER_AT_LARGE
}

enum NewsletterStatus {
  DRAFT
  PENDING_APPROVAL
  CHANGES_REQUESTED
  APPROVED
  SENT
}

model BoardRole {
  id          String        @id @default(uuid())
  patientId   String
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  role        BoardRoleType
  fromEmail   String?       // e.g. president@hemo-el-paso.org — used by Resend
  assignedBy  String        // admin email who assigned the role
  assignedAt  DateTime      @default(now())
  active      Boolean       @default(true)
  @@unique([patientId, role])
  @@index([patientId])
  @@index([role])
  @@index([active])
  @@map("board_roles")
}

model Newsletter {
  id                   String           @id @default(uuid())
  month                Int
  year                 Int
  status               NewsletterStatus @default(DRAFT)
  presidentMessageEn   String?
  presidentMessageEs   String?
  generatedContentJson Json
  revisionNotes        String?
  sentAt               DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  @@unique([month, year])
  @@index([status])
  @@index([year, month])
  @@map("newsletters")
}

model BoardMinutes {
  id              String   @id @default(uuid())
  meetingDate     DateTime
  title           String
  content         Json
  isPublic        Boolean  @default(false)
  markedPublicBy  String?
  markedPublicAt  DateTime?
  uploadedBy      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isPublic])
  @@index([meetingDate])
  @@map("board_minutes")
}

model EmailTemplate {
  id          String            @id @default(uuid())
  type        EmailTemplateType @unique
  name        String            // Display name like "RSVP Confirmation"
  subject     String            // Email subject line with variables
  enabled     Boolean           @default(true)
  
  // We'll render React components, but store descriptions here
  description String?           // What this email is for
  variables   Json              // Available variables like ["patientName", "eventTitle"]
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  @@map("email_templates")
}

model EmailLog {
  id          String   @id @default(uuid())
  templateType EmailTemplateType
  recipient   String   // Email address
  subject     String
  status      String   // "sent", "failed", "bounced"
  error       String?  // Error message if failed
  
  // Optional relations
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  
  sentAt      DateTime @default(now())
  
  @@index([patientId])
  @@index([eventId])
  @@index([sentAt])
  @@map("email_logs")
}


model PatientPreferences {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  interestedTopics     String[] 
  preferredEventTimes  String[] 
  maxTravelDistance    Int      @default(30)
  dietaryRestrictions  String[] 
  accessibilityNeeds   String?
  emailNotifications   Boolean  @default(true)
  smsNotifications     Boolean  @default(false)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("patient_preferences")
}

model Patient {
  id                String    @id @default(uuid())
  auth0Id           String    @unique
  email             String    @unique
  role              String    @default("patient") 
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  registrationCompletedAt DateTime?
  consentDate             DateTime?
  consentToContact        Boolean   @default(false)
  consentToPhotos         Boolean   @default(false)

  diagnosisGracePeriodEndsAt DateTime?
  diagnosisGracePeriodSource String?

  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?

  wantsToVolunteer     Boolean   @default(false)
  volunteerRequestedAt DateTime?

  contactProfile    ContactProfile?
  disorderProfile   DisorderProfile?
  familyMembers     FamilyMember[]
  preferences       PatientPreferences?
  rsvps             Rsvp[]
  checkIns          CheckIn[]
  auditLogs         AuditLog[]
  financialAssistanceApplications FinancialAssistanceApplication[]
  emailLogs         EmailLog[]
  boardRoles        BoardRole[]
  primaryOfFamily   Family?           @relation("FamilyPrimary")
  familyMemberships FamilyMembership[]
  volunteerProfile  VolunteerProfile?

  @@map("patients")
}

model ContactProfile {
  id           String    @id @default(uuid())
  patientId    String?   @unique
  familyMemberId String? @unique
  
  firstName    String
  lastName     String
  phone        String?
  dateOfBirth  DateTime?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  
  patient       Patient?       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  familyMember  FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@map("contact_profiles")
}

model DisorderProfile {
  id             String    @id @default(uuid())
  patientId      String?   @unique
  familyMemberId String?   @unique
  

  condition      String
  severity       String?
  dateOfDiagnosis DateTime?
  

  treatingPhysician String?
  specialtyPharmacy String?
  

  diagnosisLetterUrl        String?
  diagnosisLetterKey        String?   
  diagnosisLetterUploadedAt DateTime?
  diagnosisVerified         Boolean   @default(false)
  diagnosisVerifiedBy       String?   
  diagnosisVerifiedAt       DateTime?
  diagnosisRejectedReason   String?   
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  
  patient       Patient?       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  familyMember  FamilyMember?  @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@map("disorder_profiles")
}


model FamilyMember {
  id               String    @id @default(uuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  relationship     String    
  hasBleedingDisorder Boolean @default(false)
  
  migratedToPatientId String?   @unique
  migratedAt          DateTime?
  migrationEligibleAt DateTime? // Calculated: dateOfBirth + 18 years
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  contactProfile   ContactProfile?
  disorderProfile  DisorderProfile?

  @@map("family_members")
}

model Event {
  id            String  @id @default(uuid())
  slug          String  @unique
  titleEn       String
  titleEs       String
  descriptionEn String?
  descriptionEs String?

  flyerEnUrl String?
  flyerEsUrl String?

  eventDate    DateTime
  location     String
  maxCapacity  Int?
  rsvpDeadline DateTime?
  status       String    @default("draft")

  category       String  @default("FAMILY_SUPPORT")
  targetAudience String  @default("all")
  language       String  @default("both")
  isPriority     Boolean @default(false)
  liveEnabled    Boolean @default(false)
  eventCost  Decimal? @db.Decimal(10, 2)

  // Recap (post-event)
  recapTitleEn         String?
  recapTitleEs         String?
  recapBodyEn          String?
  recapBodyEs          String?
  recapGalleryEmbedUrl String?
  recapPublishedAt     DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targeting           EventTargeting?
  rsvps               Rsvp[]
  checkIns            CheckIn[]
  pollCreationTokens  PollCreationToken[]
  photos              EventPhoto[]
  questions           EventQuestion[]
  sponsorAccessTokens SponsorAccessToken[]
  announcements       EventAnnouncement[]
  itineraryItems      EventItineraryItem[]
  polls               Poll[]
  emailLogs EmailLog[]
  presenterTokens       PresenterAccessToken[]
  presentation          EventPresentation?
  volunteerAssignments  VolunteerEventAssignment[]
  timecards             VolunteerTimecard[]
  sponsors              EventSponsor[]

  @@map("events")
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  logoKey   String?
  tier      String   @default("PARTNER") // PLATINUM | GOLD | SILVER | BRONZE | PARTNER
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events EventSponsor[]

  @@map("sponsors")
}

model EventSponsor {
  id         String  @id @default(uuid())
  eventId    String
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId  String
  sponsor    Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Restrict)

  @@unique([eventId, sponsorId])
  @@index([eventId])
  @@index([sponsorId])
  @@map("event_sponsors")
}

model FinancialAssistanceApplication {
  id                String            @id @default(uuid())
  patientId         String
  patient           Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  // Application Details
  assistanceType    AssistanceType
  requestedAmount   Decimal           @db.Decimal(10, 2)
  purpose           String            // What the money is for
  description       String?           // Additional context
  
  // Status & Review
  status            AssistanceStatus  @default(DRAFT)
  reviewedBy        String?           // Admin email who reviewed
  reviewedAt        DateTime?
  reviewNotes       String?           // Admin notes on approval/denial
  
  // Approval Details
  approvedAmount    Decimal?          @db.Decimal(10, 2) // May differ from requested
  
  // Metadata
  submittedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  documents         AssistanceDocument[]
  disbursements     AssistanceDisbursement[]
  
  @@map("financial_assistance_applications")
}

model AssistanceDocument {
  id            String                        @id @default(uuid())
  applicationId String
  application   FinancialAssistanceApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  // File Details
  fileName      String
  fileUrl       String  // R2 URL
  fileKey       String  // R2 key for deletion
  fileSize      Int     // bytes
  mimeType      String
  
  // Metadata
  description   String? // What this document is (receipt, bill, prescription, etc)
  uploadedBy    String  // Patient email
  uploadedAt    DateTime @default(now())
  
  @@map("assistance_documents")
}

model AssistanceDisbursement {
  id                  String                        @id @default(uuid())
  applicationId       String
  application         FinancialAssistanceApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  // Payment Details
  amount              Decimal           @db.Decimal(10, 2)
  paymentMethod       PaymentMethod
  checkNumber         String?           // If paid by check
  
  // Timing
  issueDate           DateTime          // When check was written/payment made
  cashedDate          DateTime?         // When check was cashed (if known)
  
  // Tracking
  status              DisbursementStatus @default(PENDING)
  issuedBy            String            // Admin email who processed
  notes               String?
  proofOfPaymentUrl   String?           // Scanned check, receipt, etc
  proofOfPaymentKey   String?           // R2 key
  
  // Metadata
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  @@map("assistance_disbursements")
}


model EventPhoto {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  url     String // R2 URL
  key     String // R2 key for deletion
  caption String?

  approved               Boolean @default(false)
  selectedForNewsletter  Boolean @default(false)
  sessionToken  String?   
  source        String    @default("admin")   

  uploadedBy String // Admin email
  uploadedAt DateTime @default(now())

  @@map("event_photos")
  @@index([approved])
  @@index([selectedForNewsletter])
  @@index([source])
}

model EventTargeting {
  id                String   @id @default(uuid())
  eventId           String   @unique
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  targetConditions  String[] // hemophilia_a, hemophilia_b, von_willebrand, other
  targetSeverity    String[] // mild, moderate, severe
  targetAgeGroups   String[] // children, teens, adults, seniors
  targetInterests   String[] // Can map to EventTopic enum values
  requireInhibitors Boolean?

  @@map("event_targeting")
}

model Rsvp {
  id                  String   @id @default(uuid())
  eventId             String
  patientId           String
  familyId            String?
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  family              Family?  @relation(fields: [familyId], references: [id], onDelete: SetNull)
  status              String   @default("confirmed")
  attendeeCount       Int
  dietaryRestrictions String?
  specialNeeds        String?
  rsvpDate            DateTime @default(now())
  updatedAt           DateTime @updatedAt
  reminderSent        Boolean  @default(false)
  familyMembershipIds String[] @default([])

  @@unique([eventId, patientId])
}

model CheckIn {
  id                  String   @id @default(uuid())
  eventId             String
  patientId           String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  checkInTime         DateTime @default(now())
  checkOutTime        DateTime?
  checkedInBy         String?
  sessionToken        String   @unique
  sessionExpiresAt    DateTime
  attendeeRole        String   @default("patient") // patient, sponsor, donor, admin, volunteer
  familyMembershipIds String[] @default([])
  timecardId          String?  // no FK — set after VolunteerTimecard created

  @@unique([eventId, patientId])
  @@map("check_ins")
}

model SponsorAccessToken {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  token        String   @unique
  sponsorEmail String
  sponsorName  String?
  companyName  String?
  expiresAt    DateTime

  createdBy String // admin who generated
  createdAt DateTime @default(now())

  @@map("sponsor_access_tokens")
}

model PollCreationToken {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  token     String   @unique
  repEmail  String
  repName   String?
  expiresAt DateTime

  createdBy String // admin who generated the link
  createdAt DateTime @default(now())

  @@map("poll_creation_tokens")
  
}

model Poll {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  questionEn String
  questionEs String
  status     String  @default("draft") // draft, pending, approved, active
  active     Boolean @default(false)
  selectedForNewsletter  Boolean @default(false)

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options   PollOption[]
  responses PollResponse[]

@@index([selectedForNewsletter])
  @@map("polls")
}

model PollOption {
  id     String @id @default(uuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  textEn String
  textEs String

  @@map("poll_options")
}

model PollResponse {
  id               String   @id @default(uuid())
  pollId           String
  poll             Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  sessionToken     String
  selectedOptionId String
  createdAt        DateTime @default(now())

  @@unique([pollId, sessionToken])
  @@map("poll_responses")
}

model EventQuestion {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Question Content
  questionEn   String
  questionEs   String
  originalLang String @default("en")

  //submitter info
  patientId    String?
  patientName  String?
  isAnonymous  Boolean @default(false)
  sessionToken String

  // Engagement
  upvotes   Int      @default(0)
  upvotedBy String[] @default([])

  // Answer
  answered   Boolean   @default(false)
  answerEn   String?
  answerEs   String?
  answeredBy String?
  answeredAt DateTime?

  selectedForNewsletter  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([selectedForNewsletter])
}

enum AuditAction {
  // Patient & Profile
  REGISTRATION_COMPLETED
  PROFILE_UPDATED
  PATIENT_VIEWED

  // RSVP
  RSVP_CREATED
  RSVP_CANCELLED

  // Events (admin)
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  EVENT_PHOTOS_UPLOADED
  EVENT_PHOTO_DELETED
  EVENT_FLYERS_UPDATED

  // Announcements & Itinerary
  ANNOUNCEMENT_CREATED
  ANNOUNCEMENT_DELETED
  ITINERARY_ITEM_CREATED
  ITINERARY_ITEM_UPDATED
  ITINERARY_ITEM_DELETED

  // Financial Assistance (patient)
  ASSISTANCE_APPLICATION_CREATED
  ASSISTANCE_APPLICATION_UPDATED

  // Financial Assistance (admin)
  ASSISTANCE_APPLICATION_VIEWED
  ASSISTANCE_APPLICATION_APPROVED
  ASSISTANCE_APPLICATION_DENIED
  ASSISTANCE_DISBURSEMENT_CREATED
  ASSISTANCE_DOCUMENT_UPLOADED
  ASSISTANCE_DOCUMENT_DELETED
  DISBURSEMENT_PROOF_UPLOADED

  // Check-in
  CHECKIN_CREATED
  MANUAL_CHECKIN
  CHECKIN_REMOVED

  // Family Members
  FAMILY_MEMBER_ADDED
  FAMILY_MEMBER_UPDATED
  FAMILY_MEMBER_DELETED

  // Diagnosis Verification
  DIAGNOSIS_APPROVED
  DIAGNOSIS_REJECTED
  DIAGNOSIS_APPROVED_FAMILY
  DIAGNOSIS_REJECTED_FAMILY

  // User Management
  USER_UPDATED
  USER_DELETED
  USERS_EXPORTED

  // Polls & Questions
  POLL_CREATED
  POLL_DELETED
  POLL_APPROVED
  POLL_ACTIVATED
  POLL_DEACTIVATED
  POLL_INVITE_SENT
  QUESTION_DELETED
  QUESTION_ANSWERED

  // Settings
  EMAIL_TEMPLATE_UPDATED
  TEST_EMAIL_SENT

  // Sponsorship
  SPONSOR_INVITE_SENT

  NEWSLETTER_GENERATED
  NEWSLETTER_APPROVED
  NEWSLETTER_REJECTED
  NEWSLETTER_SENT
  BOARD_MINUTES_UPLOADED
  BOARD_MINUTES_VISIBILITY_CHANGED
  BOARD_ROLE_ASSIGNED
  BOARD_ROLE_REMOVED 

  SCHOLARSHIP_CREATED
  SCHOLARSHIP_UPDATED
  SCHOLARSHIP_DELETED
  TAX_FILING_UPLOADED
  TAX_FILING_DELETED
  ANNUAL_REPORT_CREATED
  ANNUAL_REPORT_UPDATED

  PRESENTER_TOKEN_CREATED
  PRESENTATION_UPDATED
  ITINERARY_ITEM_STATUS_CHANGED

  // RSVP / Check-in updates
  RSVP_UPDATED
  CHECKIN_UPDATED
  CHECKOUT_RECORDED

  // Family system
  FAMILY_CREATED
  FAMILY_MEMBER_INVITED
  FAMILY_MEMBER_JOINED
  FAMILY_MEMBER_DETACHED
  FAMILY_DETACHMENT_REQUESTED
  FAMILY_DETACHMENT_APPROVED
  BOARD_APPROVAL_REQUESTED
  BOARD_APPROVAL_GRANTED
  BOARD_APPROVAL_DENIED

  // Volunteer system
  VOLUNTEER_REQUEST_SUBMITTED
  VOLUNTEER_APPROVED
  VOLUNTEER_REJECTED
  VOLUNTEER_ASSIGNED_TO_EVENT
  VOLUNTEER_ROLE_CHANGED
  VOLUNTEER_CHECKED_IN
  VOLUNTEER_CHECKED_OUT
  TIMECARD_ADJUSTED
}

model AuditLog {
  id           String      @id @default(uuid())
  patientId    String?
  patient      Patient?    @relation(fields: [patientId], references: [id], onDelete: SetNull)
  action       AuditAction
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  details      String?
  changes      Json?
  createdAt    DateTime    @default(now())

  @@map("audit_logs")
}

model EventAnnouncement {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  messageEn String
  messageEs String
  priority  String @default("normal") // urgent, normal, info

  active    Boolean   @default(true)
  expiresAt DateTime? // Optional auto-hide time

  createdBy String
  createdAt DateTime @default(now())

  @@map("event_announcements")
}

model EventItineraryItem {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  titleEn       String
  titleEs       String
  descriptionEn String?
  descriptionEs String?

  startTime DateTime
  endTime   DateTime?
  duration  Int? // minutes

  status        String @default("scheduled") // scheduled, current, completed, skipped
  sequenceOrder Int    @default(0)

  location String? // Room/area if different from main venue

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("event_itinerary_items")
}

model Scholarship {
  id            String   @id @default(uuid())
  recipientName String
  amount        Decimal  @db.Decimal(10, 2)
  academicYear  String   // e.g. "2025-2026"
  description   String?
  awardedAt     DateTime
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([academicYear])
  @@index([awardedAt])
  @@map("scholarships")
}

model AnnualReport {
  id                    String   @id @default(uuid())
  year                  Int      @unique
  // Auto-calculated fields (can be overridden by Treasurer)
  totalEventsHeld       Int      @default(0)
  totalAttendance       Int      @default(0)
  totalAssistancePaid   Decimal  @default(0) @db.Decimal(10, 2)
  totalScholarshipsPaid Decimal  @default(0) @db.Decimal(10, 2)
  // Treasurer manual entry
  totalSponsorIncome    Decimal? @db.Decimal(10, 2)
  totalVolunteerHours   Decimal  @default(0) @db.Decimal(8, 2)
  notes                 String?
  createdBy             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  @@index([year])
  @@map("annual_reports")
}
model TaxFiling {
  id         String   @id @default(uuid())
  year       Int      @unique
  fileUrl    String
  fileKey    String
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@map("tax_filings")
}

model PresenterAccessToken {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  token         String   @unique
  presenterName String?
  expiresAt     DateTime
  createdBy     String
  createdAt     DateTime @default(now())
  @@index([eventId])
  @@map("presenter_access_tokens")
}
model EventPresentation {
  id           String   @id @default(uuid())
  eventId      String   @unique
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  currentSlide Int      @default(0)
  isLive       Boolean  @default(false)

  slideUrlsEn        String[]
  totalSlidesEn      Int      @default(0)
  originalFileUrlEn  String?
  originalFileKeyEn  String?
  originalFileNameEn String?
  conversionJobIdEn  String?
  conversionStatusEn String   @default("done")

  slideUrlsEs        String[]
  totalSlidesEs      Int      @default(0)
  originalFileUrlEs  String?
  originalFileKeyEs  String?
  originalFileNameEs String?
  conversionJobIdEs  String?
  conversionStatusEs String   @default("done")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("event_presentations")
}

// ============================================================
// SCHEMA-001: Family system
// ============================================================

model Family {
  id               String             @id @default(uuid())
  name             String
  primaryPatientId String             @unique
  primaryPatient   Patient            @relation("FamilyPrimary", fields: [primaryPatientId], references: [id])
  memberships      FamilyMembership[]
  rsvps            Rsvp[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  @@map("families")
}

model FamilyMembership {
  id                   String                 @id @default(uuid())
  familyId             String
  family               Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  patientId            String?
  patient              Patient?               @relation(fields: [patientId], references: [id], onDelete: SetNull)
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  relationship         String
  ageTier              AgeTier                @default(RECORD_ONLY)
  status               FamilyMembershipStatus @default(ACTIVE)
  inviteEmail          String?
  inviteSentAt         DateTime?
  inviteAcceptedAt     DateTime?
  parentalConsentGiven Boolean                @default(false)
  parentalConsentAt    DateTime?
  parentalConsentBy    String?
  hasBleedingDisorder  Boolean                @default(false)
  disorderCondition    String?
  disorderSeverity     String?
  diagnosisLetterUrl   String?
  diagnosisLetterKey   String?
  diagnosisVerified    Boolean                @default(false)
  diagnosisVerifiedBy  String?
  diagnosisVerifiedAt  DateTime?
  detachedAt           DateTime?
  detachedBy           String?
  detachReason         String?
  boardApprovalId      String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([familyId])
  @@index([patientId])
  @@index([status])
  @@map("family_memberships")
}

model BoardApproval {
  id           String              @id @default(uuid())
  type         BoardApprovalType
  status       BoardApprovalStatus @default(PENDING)
  requestedBy  String
  requestedAt  DateTime            @default(now())
  reviewedBy   String?
  reviewedAt   DateTime?
  notes        String?
  resourceType String?
  resourceId   String?

  @@index([status])
  @@index([type])
  @@map("board_approvals")
}

// ============================================================
// SCHEMA-002: Volunteer system
// ============================================================

model VolunteerProfile {
  id                  String                     @id @default(uuid())
  patientId           String                     @unique
  patient             Patient                    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status              VolunteerStatus            @default(PENDING_REVIEW)
  approvedBy          String?
  approvedAt          DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  rejectionReason     String?
  internalNotes       String?
  generalAvailability Json?
  skills              Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  applications        VolunteerApplication[]
  eventAssignments    VolunteerEventAssignment[]
  timecards           VolunteerTimecard[]

  @@index([status])
  @@map("volunteer_profiles")
}

model VolunteerApplication {
  id                 String           @id @default(uuid())
  volunteerProfileId String
  volunteerProfile   VolunteerProfile @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)
  whyVolunteering    String?
  skills             String?
  availability       String?
  priorExperience    String?
  references         Json?
  submittedAt        DateTime?
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNotes        String?

  @@map("volunteer_applications")
}

model VolunteerEventAssignment {
  id                   String           @id @default(uuid())
  volunteerProfileId   String
  volunteerProfile     VolunteerProfile @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)
  eventId              String
  event                Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  role                 VolunteerEventRole @default(GENERAL_SUPPORT)
  assignedBy           String
  assignedAt           DateTime         @default(now())
  accessToken          String           @unique @default(uuid())
  accessTokenExpiresAt DateTime?
  notes                String?

  @@unique([volunteerProfileId, eventId])
  @@map("volunteer_event_assignments")
}

model VolunteerTimecard {
  id                 String                  @id @default(uuid())
  volunteerProfileId String
  volunteerProfile   VolunteerProfile        @relation(fields: [volunteerProfileId], references: [id], onDelete: Cascade)
  eventId            String
  event              Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkInTime        DateTime                @default(now())
  checkOutTime       DateTime?
  totalHours         Decimal?                @db.Decimal(5, 2)
  status             String                  @default("active")
  adjustedBy         String?
  adjustedAt         DateTime?
  adjustmentNotes    String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  roles              VolunteerTimecardRole[]

  @@map("volunteer_timecards")
}

model VolunteerTimecardRole {
  id         String             @id @default(uuid())
  timecardId String
  timecard   VolunteerTimecard  @relation(fields: [timecardId], references: [id], onDelete: Cascade)
  role       VolunteerEventRole
  startTime  DateTime
  endTime    DateTime?
  assignedBy String?
  notes      String?

  @@map("volunteer_timecard_roles")
}